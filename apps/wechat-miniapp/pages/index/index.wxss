.container {
  padding: 0;
  background-color: var(--color-bg-positive);
  min-height: 100vh;
  width: 100%;
}

/* 第一行：鼓舞语句轮播 */
.quotes-swiper {
  width: 100%;
  height: 90rpx;
  background-color: var(--color-accent-soft); /* 与主背景相同颜色 */
  margin-bottom: var(--spacing-row);
}

.quote-item {
  line-height: 90rpx;
  font-size: 28rpx;
  color: var(--color-text-main);
  text-align: center;
  font-weight: 500;
}

/* 第二行：搜索组件 */
.search-row {
  width: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
  margin-bottom: var(--spacing-row);
}

.search-bar {
  background-color: var(--color-surface);
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid var(--color-border);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.search-bar input {
  font-size: 28rpx;
  margin-left: 16rpx;
  flex: 1;
  color: var(--color-text-secondary);
}

/* 第三行：招呼/去登录 */
.greeting-row {
  width: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
  margin-bottom: var(--spacing-row);
}

.greeting-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-main);
}

.login-link {
  font-size: 30rpx;
  color: var(--color-accent-warm); /* 显示蓝色 */
  text-decoration: none;
  font-weight: 500;
}

/* 功能卡片 */
.main-card {
  width: 100%;
  background-color: var(--color-surface);
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
  border-top: 1rpx solid var(--color-border);
  border-bottom: 1rpx solid var(--color-border);
}

.grid-2 {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
}

.grid-4 {
  display: flex;
  justify-content: space-between;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 16rpx;
}

.item-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.add-patient-row {
  border-top: 1rpx solid var(--color-border);
  padding-top: 30rpx;
  text-align: center;
}

.add-text {
  color: var(--color-text-main);
  font-size: 30rpx;
  font-weight: 500;
}

/* 版权小字 */
.copyright {
  width: 100%;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-disabled);
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
