{
  "name": "ai-adolescent-mental-health-platform",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && node -e \"require('node:fs').rmSync('.turbo', { recursive: true, force: true })\"",
    "dev": "turbo run dev --parallel",
    "dev:backend": "pnpm --filter @ai-adolescent-mental-health/backend dev",
    "dev:web-client": "pnpm --filter @ai-adolescent-mental-health/web-client dev",
    "dev:web-admin": "pnpm --filter @ai-adolescent-mental-health/web-admin dev",
    "dev:web-user": "pnpm --filter @ai-adolescent-mental-health/web-user dev",
    "test": "turbo run test",
    "test:android": "pnpm --filter @ai-adolescent-mental-health/android test",
    "test:backend": "pnpm --filter @ai-adolescent-mental-health/backend test",
    "typecheck": "turbo run typecheck",
    "typecheck:web-admin": "pnpm --filter @ai-adolescent-mental-health/web-admin typecheck",
    "typecheck:web-user": "pnpm --filter @ai-adolescent-mental-health/web-user typecheck"
  },
  "devDependencies": {
    "turbo": "2.9.6"
  }
}
