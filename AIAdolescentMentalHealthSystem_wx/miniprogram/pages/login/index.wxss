.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  height: 100vh;
  background-color: #fff;
}
.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 40rpx;
}
.title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 80rpx;
}
.login-btn {
  width: 80% !important;
  border-radius: 40rpx;
  background-color: #07c160;
}
.tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}